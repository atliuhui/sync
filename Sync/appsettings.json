{
  "Device": {
    "Camera": {
      "Namespaces": [ "com.apple.quicktime.model", "com.android.marketing_name" ]
    }
  },
  "Storage": {
    "Caching": {
      "Path": "Downloads/Gallery",
      "IndexFile": {
        "Name": "tracking.csv"
      }
    },
    "Gallery": {
      "Path": "syncs/Gallery",
      "Subfolder": {
        "Name": {
          "Template": "{{Date|date:'%Y'}}/{{Date|date:'%Y-%m-%d'}}"
        }
      }
    }
  },
  "Ignore": {
    "File": {
      "Prefix": [ ".", "~$" ],
      "Suffix": [ ".db", ".sqlite", ".ithmb", ".plj", ".graphdb", ".kgdb" ]
    },
    "Directory": {
      "Prefix": [ "#", "$recycle.bin", "recycler", "System Volume Information" ],
      "Suffix": [ ".del" ]
    }
  },
  "Mapping": {
    "CategoryProvider": {
      ".mp3": "audio",
      ".wav": "audio",
      ".m4a": "audio",
      ".wma": "audio",
      ".flac": "audio",
      ".mp4": "video",
      ".m4v": "video",
      ".mkv": "video",
      ".mov": "video",
      ".mpg": "video",
      ".mts": "video",
      ".avi": "video",
      ".wmv": "video",
      ".jpg": "image",
      ".jpeg": "image",
      ".aae": "ignore",
      ".png": "image",
      ".gif": "image",
      ".heic": "image",
      ".bmp": "image",
      ".cr2": "image",
      ".nef": "image",
      ".doc": "document",
      ".docx": "document",
      ".ppt": "document",
      ".pptx": "document",
      ".xls": "document",
      ".xlsx": "document",
      ".pdf": "document",
      ".csv": "document",
      ".zip": "document",
      ".rar": "document"
    }
  },
  "Grok": {
    "Cores": [
      "WORD (?:\\b\\w+\\b)",
      "OWORD (?:[A-Za-z]+)",
      "DWORD (?:\\w+)",
      "XWORD (?:[A-Za-z0-9.]+)",
      "YEAR (?:(?>\\d\\d){1,2})",
      "MONTHNUM (?:0?[1-9]|1[0-2])",
      "MONTHDAY (?:0?[1-9]|[12][0-9]|3[01])",
      "HOUR (?:2[0-3]|[01]?[0-9])",
      "MINUTE (?:[0-5][0-9])",
      "SECOND (?:(?:[0-5][0-9]|60)(?:[:.,][0-9]+)?)",
      "TIMESTAMP1 (?:(?:\\d{4})(?:\\d{2})(?:\\d{2})(?:\\d{2})(?:\\d{2})(?:\\d{2}))",
      "TIMESTAMP2 (?:(?:\\d{4})(?:\\d{2})(?:\\d{2})_(?:\\d{2})(?:\\d{2})(?:\\d{2}))",
      "TIMESTAMP3 (?:(?:\\d{4})(?:\\d{2})(?:\\d{2})_(?:\\d{2})(?:\\d{2})(?:\\d{2})_(?:\\d{3}))",
      "TIMESTAMP4 (?:(?:\\d{4})-(?:\\d{2})-(?:\\d{2})-(?:\\d{2})(?:\\d{2})(?:\\d{2})(?:\\d{3}))",
      "TIMESTAMP5 (?:(?:\\d{4})-(?:\\d{2})-(?:\\d{2})-(?:\\d{2})-(?:\\d{2})-(?:\\d{2})-(?:\\d{3}))"
    ],
    "Patterns": {
      "Dates": [
        {
          "Pattern": "^%{OWORD:prefix}%{TIMESTAMP1:date}(?:_%{DWORD:extra})?",
          "Format": "yyyyMMddHHmmss",
          "Samples": [ "IMG20180919141601", "IMG20190507105436_1", "VID20180716151918" ]
        },
        {
          "Pattern": "^%{OWORD:prefix}_%{TIMESTAMP3:date}(?:_%{DWORD:extra})?",
          "Format": "yyyyMMdd_HHmmss_fff",
          "Samples": [ "IMG_20230116_185229_191_01673866349943" ]
        },
        {
          "Pattern": "^%{OWORD:prefix}_%{TIMESTAMP2:date}(?:_%{DWORD:extra})?",
          "Format": "yyyyMMdd_HHmmss",
          "Samples": [ "IMG_20160515_093456", "IMG_20180204_204850_HDR", "IMG_20190529_115107_Burst01", "Screenshot_20250316_090912", "video_20190514_201220", "VID_20160324_161425" ]
        },
        {
          "Pattern": "^%{OWORD:prefix}-%{TIMESTAMP4:date}(?:%{DWORD:extra})?",
          "Format": "yyyy-MM-dd-HHmmssfff",
          "Samples": [ "TG-2023-01-16-1859214871673866762188", "TG-2023-05-10-102757125" ]
        },
        {
          "Pattern": "^%{OWORD:prefix}_%{TIMESTAMP5:date}(?:_%{XWORD:extra})?",
          "Format": "yyyy-MM-dd-HH-mm-ss-fff",
          "Samples": [ "Screenshot_2023-04-06-19-02-32-871_com.eg.android.AlipayGphone" ]
        }
      ]
    }
  }
}
